; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but we're bootstrapping here.

[application]

config/name="MonsterQuest"
config/description="A Pokémon-inspired monster catching RPG"
run/main_scene="res://scenes/overworld/overworld.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")

[autoload]

GameManager="*res://scripts/autoload/game_manager.gd"
BattleManager="*res://scripts/autoload/battle_manager.gd"
DataLoader="*res://scripts/autoload/data_loader.gd"
AudioManager="*res://scripts/autoload/audio_manager.gd"

[display]

window/size/viewport_width=480
window/size/viewport_height=320
window/size/window_width_override=960
window/size/window_height_override=640
window/stretch/mode="viewport"
window/stretch/aspect="keep"

